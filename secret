local clicks = 0
local maxClicks = 8
local idx = 1

local function randomPosForButton()
	-- usa scale pra evitar problemas com offsets em resoluções diferentes
	local sx = math.random(10,90)/100
	local sy = math.random(60,92)/100
	return UDim2.new(sx, 0, sy, 0)
end

local function tinyFlee()
	local newPos = randomPosForButton()
	local tween = TweenService:Create(closeBtn, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = newPos})
	tween:Play()
end

local function showImage(i)
	if i < 1 then i = 1 end
	if i > #slideshow then i = ((i-1) % #slideshow) + 1 end
	local id = slideshow[i]
	pcall(function() ContentProvider:PreloadAsync({id}) end)
	img.Image = id
	warn("[Scary] mostrando slide "..tostring(i).." -> "..tostring(id))
end

