	local tries = 0
	while ScreenGui.Parent and tries < 8 do
		if not pcall(function() return sound.IsPlaying end) or not sound.IsPlaying then
			safePlay(sound)
		end
		tries = tries + 1
		wait(0.8)
	end
end)

