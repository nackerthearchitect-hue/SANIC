-- preload com retries
local function preload(asset, tries)
	tries = tries or 3
	for i = 1, tries do
		local ok = pcall(function() ContentProvider:PreloadAsync({asset}) end)
		if ok then return true end
		wait(0.35)
	end
	return false
end

for i, id in ipairs(slideshow) do
	local ok = preload(id, 4)
	warn(string.format("[Scary] preload slide %d -> %s (ok=%s)", i, id, tostring(ok)))
end
